<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondomain"
    tools:context=".Horario">

    <!-- Título QuickPass8 -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


    </LinearLayout>

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:letterSpacing="0.2"
        android:text="··· Horario ···"
        android:textColor="#8A7AAA"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader" />

    <!-- Card con la imagen del horario -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardHorario"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toTopOf="@id/layoutBotones"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitulo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Imagen del horario -->
            <ImageView
                android:id="@+id/imgHorario"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Foto del horario"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_gallery" />

            <!-- Texto cuando no hay imagen -->
            <TextView
                android:id="@+id/tvSinFoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Toca el botón para\nagregar tu horario 📅"
                android:textColor="#8A7AAA"
                android:textSize="14sp"
                android:visibility="visible" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Botones abajo -->
    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnInicio"
            android:layout_width="110dp"
            android:layout_height="50dp"
            android:layout_marginEnd="12dp"
            android:background="@null"
            android:contentDescription="Inicio"
            android:scaleType="fitCenter"
            android:src="@drawable/btniinicio" />

        <ImageButton
            android:id="@+id/btnAgregarFoto"
            android:layout_width="110dp"
            android:layout_height="50dp"
            android:background="@null"
            android:contentDescription="Agregar foto"
            android:scaleType="fitCenter"
            android:src="@drawable/btniagrega" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>