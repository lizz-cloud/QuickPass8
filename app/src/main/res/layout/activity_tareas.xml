<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondotareas"
    tools:context=".Tareas">

    <!-- ScrollView para que las notas sean scrolleables -->

    <!-- Botones fijos abajo -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="339dp"
        android:layout_height="528dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutBotones"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.49"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/contenedorNotas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="24dp" />

    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Botón Inicio -->
        <ImageButton
            android:id="@+id/btnInicio"
            android:layout_width="120dp"
            android:layout_height="50dp"
            android:layout_marginEnd="16dp"
            android:background="@null"
            android:contentDescription="inicio"
            android:scaleType="fitCenter"
            android:src="@drawable/btninicio" />

        <!-- Botón Agregar -->
        <ImageButton
            android:id="@+id/btnAgregar"
            android:layout_width="120dp"
            android:layout_height="50dp"
            android:background="@null"
            android:contentDescription="agreg"
            android:scaleType="fitCenter"
            android:src="@drawable/btnagregar" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>