<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondomain"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="400dp"
        android:layout_height="700dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Space
            android:layout_width="match_parent"
            android:layout_height="50dp" />

        <!-- Título QuickPass8 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:fontFamily="@font/abril_fatface"
            android:text="    Quick"
            android:textAlignment="center"
            android:textColor="#3467AF"
            android:textSize="60sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:fontFamily="@font/abril_fatface"
            android:gravity="center"
            android:text="    Pass8"
            android:textAlignment="center"
            android:textColor="#3467AF"
            android:textSize="60sp"
            android:textStyle="bold" />

        <!-- Subtítulo "Inicio de sesión" -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_bold"
            android:text="             ··· Inicio de sesión ···"
            android:textAlignment="center"
            android:textColor="#1C209F"
            android:textSize="14sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Texto "Accede a tu cuenta" -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_bold"
            android:text="             Accede a tu cuenta"
            android:textAlignment="center"
            android:textColor="#1C209F"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/lato_bold"
            android:text="             Ingresa tu boleta o numero de  trabajador para continuar"
            android:textAlignment="center"
            android:textColor="#888888"
            android:textSize="12sp" />

        <!-- Fila: gato + campos -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="200dp"
            android:orientation="horizontal">

            <!-- Gato en medio/izquierda (tu drawable original) -->

            <!-- Campos de texto -->

            <Space
                android:layout_width="80dp"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="260dp"
                android:layout_height="200dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="30dp" />

                <!-- Campo Usuario -->
                <EditText
                    android:id="@+id/txtUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/nomusuario"
                    android:ems="10"
                    android:gravity="center"
                    android:hint="       No.boleta / No.trabajador"
                    android:inputType="text"
                    android:textAlignment="center"
                    android:textSize="14sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="40dp" />

                <!-- Campo Contraseña con toggle -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/txteContra"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/contra"
                        android:gravity="center|top"
                        android:hint="    Contraseña"
                        android:inputType="textPassword"
                        android:textAlignment="center"
                        android:textStyle="bold" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <Space
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <!-- ¿Olvidaste tu contraseña? -->
        <TextView
            android:id="@+id/tvOlvideContrasena"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_bold"
            android:text="        ¿Olvidaste tu contraseña?"
            android:textAlignment="center"
            android:textColor="#1C209F"
            android:textSize="12sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <Space
                android:layout_width="54dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="250dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Botón Iniciar sesión -->
                <Button
                    android:id="@+id/button"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:backgroundTint="#3467AF"
                    android:fontFamily="@font/lato_bold"
                    android:onClick="Iniciar"
                    android:text="Iniciar sesión"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="20dp" />

                <!-- Link ¿No tienes cuenta? -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lato_bold"
                        android:text="¿No tienes cuenta? "
                        android:textColor="#888888"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvRegistrate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lato_bold"
                        android:text="Regístrate"
                        android:textColor="#1C209F"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:onClick="Registro"/>
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="20dp" />

                <!-- Footer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lato_bold"
                        android:text="QuickPass8 · "
                        android:textColor="#3467AF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/lato_bold"
                        android:text="Sistema escolar seguro y confiable"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_weight="1" />

            </LinearLayout>

            <Space
                android:layout_width="54dp"
                android:layout_height="match_parent" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="408dp"
        android:layout_height="494dp"
        android:layout_marginStart="35dp"
        android:layout_marginBottom="275dp"
        android:background="@drawable/gato"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/linearLayout"></LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
